      "update": false,
      "delete": false
    },
    "authenticated": {
      "read": true,
      "create": true,
      "update": false,
      "delete": false
    },
    "roles": {
      "admin": {
        "read": true,
        "create": true,
        "update": true,
        "delete": true
      },
      "superadmin": {
        "read": true,
        "create": true,
        "update": true,
        "delete": true
      }
    }
  }
}
