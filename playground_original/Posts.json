      "type": "string",
      "required": true
    },
    "description": {
      "type": "string",
      "longtext": true,
      "required": true
    },
    "comments": [
      {
        "type": "ObjectId",
        "ref": "Comments"
      }
    ]
  },
  "allowedMethods": {
